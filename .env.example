# MongoDB
MONGODB_URI=mongodb://mongo:27017
MONGODB_DATABASE=resume_analyzer

# LLM Provider — localai | openai
# Set to "openai" and update LLM_BASE_URL + LLM_API_KEY to use OpenAI or Gemini instead
LLM_PROVIDER=localai
LLM_BASE_URL=http://localai:8080/v1
LLM_API_KEY=localai-key
LLM_MODEL=phi-4-mini
LLM_TIMEOUT_SECONDS=120
LLM_MAX_RETRIES=3

# API
APP_ENV=development
APP_DEBUG=true
